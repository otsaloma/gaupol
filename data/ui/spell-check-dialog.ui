<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="dialog">
    <property name="title" translatable="1">Check Spelling</property>
    <property name="modal">1</property>
    <property name="use_header_bar">1</property>
    <signal name="response" handler="_on_response" swapped="no"/>
    <child internal-child="content_area">
      <object class="GtkBox" id="dialog-vbox1">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkGrid" id="grid">
            <property name="margin_start">18</property>
            <property name="margin_end">18</property>
            <property name="margin_top">18</property>
            <property name="margin_bottom">18</property>
            <property name="hexpand">1</property>
            <property name="vexpand">1</property>
            <property name="row_spacing">6</property>
            <property name="column_spacing">12</property>
            <child>
              <object class="GtkBox" id="button_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkBox" id="join_button_box">
                    <property name="orientation">vertical</property>
                    <style>
                      <class name="linked"/>
                    </style>
                    <child>
                      <object class="GtkButton" id="join_back_button">
                        <property name="label" translatable="1">Join _Back</property>
                        <property name="focusable">1</property>
                        <property name="receives_default">1</property>
                        <property name="use_underline">1</property>
                        <signal name="clicked" handler="_on_join_back_button_clicked" swapped="no"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="join_forward_button">
                        <property name="label" translatable="1">Join _Forward</property>
                        <property name="focusable">1</property>
                        <property name="receives_default">1</property>
                        <property name="use_underline">1</property>
                        <signal name="clicked" handler="_on_join_forward_button_clicked" swapped="no"/>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="edit_button">
                    <property name="label" translatable="1">_Edit</property>
                    <property name="focusable">1</property>
                    <property name="receives_default">1</property>
                    <property name="use_underline">1</property>
                    <signal name="clicked" handler="_on_edit_button_clicked" swapped="no"/>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="ignore_button_box">
                    <property name="orientation">vertical</property>
                    <style>
                      <class name="linked"/>
                    </style>
                    <child>
                      <object class="GtkButton" id="ignore_button">
                        <property name="label" translatable="1">_Ignore</property>
                        <property name="focusable">1</property>
                        <property name="receives_default">1</property>
                        <property name="use_underline">1</property>
                        <signal name="clicked" handler="_on_ignore_button_clicked" swapped="no"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="ignore_all_button">
                        <property name="label" translatable="1">Ig_nore All</property>
                        <property name="focusable">1</property>
                        <property name="receives_default">1</property>
                        <property name="use_underline">1</property>
                        <signal name="clicked" handler="_on_ignore_all_button_clicked" swapped="no"/>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="replace_button_box">
                    <property name="orientation">vertical</property>
                    <style>
                      <class name="linked"/>
                    </style>
                    <child>
                      <object class="GtkButton" id="replace_button">
                        <property name="label" translatable="1">_Replace</property>
                        <property name="focusable">1</property>
                        <property name="receives_default">1</property>
                        <property name="use_underline">1</property>
                        <signal name="clicked" handler="_on_replace_button_clicked" swapped="no"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="replace_all_button">
                        <property name="label" translatable="1">Rep_lace All</property>
                        <property name="focusable">1</property>
                        <property name="receives_default">1</property>
                        <property name="use_underline">1</property>
                        <signal name="clicked" handler="_on_replace_all_button_clicked" swapped="no"/>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="add_button">
                    <property name="label" translatable="1">_Add</property>
                    <property name="focusable">1</property>
                    <property name="receives_default">1</property>
                    <property name="use_underline">1</property>
                    <signal name="clicked" handler="_on_add_button_clicked" swapped="no"/>
                  </object>
                </child>
                <layout>
                  <property name="column">2</property>
                  <property name="row">0</property>
                  <property name="row-span">3</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label2">
                <property name="halign">start</property>
                <property name="valign">start</property>
                <property name="margin_top">2</property>
                <property name="label" translatable="1">_Suggestions</property>
                <property name="use_underline">1</property>
                <property name="mnemonic_widget">suggestions_list</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label1">
                <property name="halign">start</property>
                <property name="label" translatable="1">Replace _with</property>
                <property name="use_underline">1</property>
                <property name="mnemonic_widget">entry</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkScrolledWindow" id="scrolledwindow1">
                <property name="has_frame">1</property>
                <property name="focusable">1</property>
                <property name="child">
                  <object class="GtkTextView" id="text_view">
                    <property name="focusable">1</property>
                    <property name="editable">0</property>
                    <property name="left_margin">6</property>
                    <property name="right_margin">6</property>
                    <property name="accepts_tab">0</property>
                  </object>
                </property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="entry">
                <property name="focusable">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkScrolledWindow" id="suggestions_scroller">
                <property name="has_frame">1</property>
                <property name="focusable">1</property>
                <property name="hexpand">1</property>
                <property name="vexpand">1</property>
                <property name="child">
                  <object class="GtkListBox" id="suggestions_list">
                    <signal name="row-selected" handler="_on_suggestions_list_row_selected" swapped="no"/>
                  </object>
                </property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
