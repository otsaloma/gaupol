<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="dialog">
    <property name="title" translatable="1">Convert Framerate</property>
    <property name="resizable">0</property>
    <property name="modal">1</property>
    <property name="use_header_bar">1</property>
    <signal name="response" handler="_on_response" swapped="no"/>
    <child internal-child="content_area">
      <object class="GtkBox" id="vbox1">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkBox" id="vbox2">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkBox" id="vbox3">
                <property name="orientation">vertical</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkLabel" id="label6">
                    <property name="valign">center</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Framerate</property>
                    <attributes>
                      <attribute name="weight" value="bold"></attribute>
                    </attributes>
                  </object>
                </child>
                <child>
                  <object class="GtkGrid" id="grid1">
                    <property name="margin_start">12</property>
                    <property name="row_spacing">6</property>
                    <property name="column_spacing">12</property>
                    <child>
                      <object class="GtkLabel" id="label8">
                        <property name="halign">start</property>
                        <property name="label" translatable="1">_Input:</property>
                        <property name="use_underline">1</property>
                        <property name="justify">center</property>
                        <property name="mnemonic_widget">input_combo</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="label9">
                        <property name="halign">start</property>
                        <property name="label" translatable="1">_Output:</property>
                        <property name="use_underline">1</property>
                        <property name="mnemonic_widget">output_combo</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkComboBox" id="input_combo">
                        <property name="hexpand">1</property>
                        <signal name="changed" handler="_on_input_combo_changed" swapped="no"/>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkComboBox" id="output_combo">
                        <property name="hexpand">1</property>
                        <signal name="changed" handler="_on_output_combo_changed" swapped="no"/>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="vbox5">
                <property name="orientation">vertical</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkLabel" id="label10">
                    <property name="valign">center</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Subtitles</property>
                    <attributes>
                      <attribute name="weight" value="bold"></attribute>
                    </attributes>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="vbox6">
                    <property name="margin_start">12</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkCheckButton" id="current_radio">
                        <property name="valign">center</property>
                        <property name="label" translatable="1">Convert c_urrent project</property>
                        <property name="focusable">1</property>
                        <property name="halign">start</property>
                        <property name="use_underline">1</property>
                        <property name="active">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="all_radio">
                        <property name="valign">center</property>
                        <property name="label" translatable="1">Convert _all open projects</property>
                        <property name="focusable">1</property>
                        <property name="halign">start</property>
                        <property name="use_underline">1</property>
                        <property name="group">current_radio</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
