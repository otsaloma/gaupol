<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adjustment1">
    <property name="lower">2</property>
    <property name="upper">999999</property>
    <property name="value">2</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
  <object class="GtkDialog" id="dialog">
    <property name="title" translatable="1">Split Project</property>
    <property name="resizable">0</property>
    <property name="modal">1</property>
    <property name="use_header_bar">1</property>
    <signal name="response" handler="_on_response" swapped="no"/>
    <child internal-child="content_area">
      <object class="GtkBox" id="dialog-vbox1">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkBox" id="hbox1">
            <property name="spacing">12</property>
            <child>
              <object class="GtkLabel" id="label1">
                <property name="halign">center</property>
                <property name="label" translatable="1">_First subtitle of new project:</property>
                <property name="use_underline">1</property>
                <property name="mnemonic_widget">subtitle_spin</property>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="subtitle_spin">
                <property name="focusable">1</property>
                <property name="adjustment">adjustment1</property>
                <property name="climb_rate">1</property>
                <property name="numeric">1</property>
                <signal name="value-changed" handler="_on_subtitle_spin_value_changed" swapped="no"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
